# Copy to web/.env

# WalletConnect (QR sign-in for mobile wallets) — free project id at https://cloud.reown.com
# MetaMask and Phantom need no configuration.
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Point the UI at a hosted API (default: same-origin /api, proxied to :8787 in dev)
# VITE_API_URL=https://api.yourapp.example
