# Copy this file to ".env" and fill in your values.

# The private key of a wallet you control (NEVER commit the real .env).
# Fund this wallet with testnet MON from https://faucet.monad.xyz
PRIVATE_KEY=0xyour_private_key_here

# Monad testnet (defaults are already correct — only set these if they change)
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
MONAD_EXPLORER=https://testnet.monadexplorer.com

# LLM: your OpenAI key for the agent brains. Enable per run with USE_AI=1.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# AI_MAX_CALLS=150             # optional — AI call budget per hour (guardrail)

# API hardening (all optional)
# API_KEY=...                  # mutating API routes then require the x-api-key header
# CORS_ORIGIN=http://localhost:5173,https://yourapp.example
# PORT=8787
